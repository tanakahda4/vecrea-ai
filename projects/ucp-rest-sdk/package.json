{
  "name": "ucp-rest-sdk",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/common/index.ts",
    "build": "vite build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "fetch-openapi-spec": "node scripts/fetch-openapi-spec.mjs",
    "generate": "pnpm fetch-openapi-spec && openapi-ts",
    "lint": "eslint .",
    "format": "prettier --write"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hey-api/openapi-ts": "^0.93.0",
    "@types/node": "^20.11.17",
    "@types/uuid": "^9.0.8",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.7.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^6.4.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "minimatch": ">=10.2.1"
  },
  "exports": {
    "./generated": {
      "types": "./dist/generated/index.d.ts",
      "import": "./dist/generated/index.mjs",
      "require": "./dist/generated/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.cjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.mjs",
      "require": "./dist/client/index.cjs"
    },
    "./common": {
      "types": "./dist/common/index.d.ts",
      "import": "./dist/common/index.mjs",
      "require": "./dist/common/index.cjs"
    }
  },
  "module": "./dist/common/index.mjs",
  "types": "./dist/common/index.d.ts"
}