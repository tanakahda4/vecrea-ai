{
  "name": "pwal",
  "version": "1.0.0",
  "description": "Programmatic wallet for CDP (Coinbase Developer Platform) with Base USDC and x402. Use as CLI, SDK, or in AI agents (Cursor/Codex) and cloud (Vercel AI SDK).",
  "type": "module",
  "bin": {
    "pwal": "bin/pwal.ts"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "tsconfig.json",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "cli": "tsx src/cli.ts",
    "run": "tsx",
    "test": "vitest run",
    "lint": "eslint .",
    "docs": "typedoc",
    "prepublishOnly": "npm run build && npm run lint && npm run test",
    "build": "npm run docs"
  },
  "keywords": [
    "cdp",
    "coinbase",
    "wallet",
    "cli",
    "sdk",
    "usdc",
    "base",
    "x402",
    "vercel",
    "ai"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/dentsusoken/vecrea-ai.git",
    "directory": "projects/programmatic-wallet"
  },
  "homepage": "https://github.com/dentsusoken/vecrea-ai/tree/main/projects/programmatic-wallet",
  "bugs": {
    "url": "https://github.com/dentsusoken/vecrea-ai/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@coinbase/cdp-core": "^0.0.85",
    "@x402/evm": "^2.4.0",
    "@x402/fetch": "^2.4.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^16.4.5",
    "localstorage-polyfill": "^1.0.1",
    "ora": "^9.3.0",
    "tsx": "^4.21.0",
    "viem": "^2.33.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "^22.0.0",
    "eslint": "^9.39.3",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  }
}